// LifeOS - AI-Powered Personal Operating System
// Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User Profile
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?
  timezone      String   @default("UTC")
  onboardingDone Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  goals         Goal[]
  habits        Habit[]
  notes         Note[]
  tasks         Task[]
  chatMessages  ChatMessage[]
  habitLogs     HabitLog[]
  focusSessions FocusSession[]
}

// Goals - Long-term objectives
model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String?  // career, health, learning, personal, finance
  status      String   @default("active") // active, completed, paused, abandoned
  priority    Int      @default(2) // 1=low, 2=medium, 3=high
  deadline    DateTime?
  progress    Int      @default(0) // 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  milestones  Milestone[]

  @@index([userId, status])
}

// Milestones - Key checkpoints for goals
model Milestone {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  completed   Boolean  @default(false)
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

// Habits - Daily/weekly recurring activities
model Habit {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  icon        String?
  color       String?  // Tailwind color class
  frequency   String   @default("daily") // daily, weekly, custom
  targetCount Int      @default(1) // times per period
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        HabitLog[]

  @@index([userId, active])
}

// Habit Logs - Track habit completions
model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime // The date the habit was logged
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
}

// Tasks - Actionable items
model Task {
  id          String   @id @default(cuid())
  userId      String
  goalId      String?
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed, cancelled
  priority    Int      @default(2) // 1=low, 2=medium, 3=high
  dueDate     DateTime?
  scheduledAt DateTime? // When the task is scheduled
  estimatedMinutes Int?
  actualMinutes    Int?
  aiSuggested Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, scheduledAt])
}

// Notes - Smart notes system
model Note {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  content     String   // Markdown content
  summary     String?  // AI-generated summary
  tags        String?  // JSON array of tags
  linkedNotes String?  // JSON array of linked note IDs
  isArchived  Boolean  @default(false)
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isArchived])
  @@index([userId, createdAt])
}

// Chat Messages - AI assistant conversations
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // user, assistant
  content   String
  context   String?  // JSON - what context was used (goals, tasks, notes)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Focus Sessions - Track focused work time
model FocusSession {
  id          String   @id @default(cuid())
  userId      String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?     // in minutes
  taskId      String?  // Optional task being worked on
  note        String?
  rating      Int?     // 1-5 self-rated productivity
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
}

// Daily Insights - AI-generated insights stored for quick access
model DailyInsight {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  insightType String   // focus_trend, habit_pattern, productivity_tip
  content     String
  data        String?  // JSON - supporting data
  createdAt   DateTime @default(now())

  @@unique([userId, date, insightType])
  @@index([userId, date])
}
